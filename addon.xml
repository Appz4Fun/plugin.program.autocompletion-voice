<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.program.autocompletion" name="AutoCompletion with Voice for Keyboard" version="3.0.0" provider-name="Philipp Temminghoff (phil65), sualfred, xulek, finkleandeinhorn">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.python.pluginsource" library="plugin.py" />
    <extension point="xbmc.service" library="service.py" start="startup" />

    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">AutoCompletion with Voice Input for the virtual keyboard</summary>
        <description lang="en_GB">AutoCompletion with Voice Input for the virtual keyboard. Use your BLE remote mic or Gemini STT to search by voice.</description>
        <platform>all</platform>
        <license>GPL-2.0-or-later</license>
        <source>https://github.com/finkleandeinhorn/script.module.autocompletion</source>
        <assets>
            <icon>resources/icon.png</icon>
            <screenshot>resources/screenshot-01.jpg</screenshot>
            <screenshot>resources/screenshot-02.jpg</screenshot>
            <screenshot>resources/screenshot-03.jpg</screenshot>
        </assets>
    </extension>
</addon>
